# ============================================================
# Story Narrator - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your API keys
# Keep .env file private and never commit it to version control!

# ============================================================
# LLM Provider Configuration
# ============================================================

# Google Gemini API (Recommended - Free tier: 15 requests/min, 1500/day)
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.5-flash  # Options: gemini-2.5-flash (fast), gemini-2.5-pro (advanced)

# ============================================================
# Chatterbox TTS Configuration
# ============================================================

# Model paths (set if models are not in default location)
# S3GEN_MODEL_PATH=/path/to/s3gen_model.safetensors
# S3TOKENIZER_MODEL_PATH=/path/to/s3tokenizer_model.safetensors
# T3_MODEL_PATH=/path/to/t3_model.safetensors
# VOICE_ENCODER_PATH=/path/to/voice_encoder.safetensors

# TTS Generation Settings
TTS_SAMPLE_RATE=24000
TTS_EMOTION_PRESET=neutral  # Options: neutral, happy, sad, angry, surprised
TTS_SPEED=1.0  # Range: 0.5 to 2.0
TTS_ENABLE_WATERMARK=false  # Set to true for commercial use

# ============================================================
# Audio Output Configuration
# ============================================================

OUTPUT_DIR=./output
OUTPUT_FORMAT=wav  # Options: wav, mp3, flac
AUDIO_BITRATE=192k  # For mp3/flac format

# ============================================================
# Advanced Settings
# ============================================================

# Logging
LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR

# Performance
DEVICE=cuda  # Options: cuda, cpu, mps (for Mac)
TORCH_THREADS=4

# Get your API keys:
# - Google Gemini: https://makersuite.google.com/app/apikey
# - OpenAI: https://platform.openai.com/api-keys
# - Anthropic: https://console.anthropic.com/
